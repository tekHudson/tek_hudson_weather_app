<% content_for :title, "Weather App - Get Current Weather Information" %>

<div class="row justify-content-center">
  <div class="col-lg-8 col-xl-6">
    <!-- Header Section -->
    <div class="text-center mb-5">
      <h1 class="display-4 fw-bold text-primary">
        <i class="fas fa-cloud-sun me-3"></i>Weather App
      </h1>
      <p class="lead text-muted">
        Get current weather information for any address
      </p>
    </div>

    <!-- Search Form Card -->
    <div class="card shadow-lg border-0">
      <div class="card-header bg-primary text-white">
        <h3 class="card-title mb-0">
          <i class="fas fa-search me-2"></i>Search Weather
        </h3>
      </div>
      <div class="card-body p-4">
        <%= form_with url: weather_show_path, method: :get, local: true, class: "needs-validation", novalidate: true, id: "weather-form" do |form| %>
          <!-- Hidden fields for coordinates and ZIP code -->
          <%= form.hidden_field :lat, id: "hidden_lat" %>
          <%= form.hidden_field :lng, id: "hidden_lng" %>
          <%= form.hidden_field :zip_code, id: "hidden_zip_code" %>
          
          <!-- Search Input -->
          <div class="mb-4">
            <label for="search_query" class="form-label fw-semibold">
              <i class="fas fa-search me-2"></i>Enter Address
            </label>
            <div class="input-group">
              <span class="input-group-text">
                <i class="fas fa-location-dot"></i>
              </span>
              <%= form.text_field :search_query, 
                  id: "search_query",
                  class: "form-control form-control-lg", 
                  placeholder: "Enter address...",
                  value: @search_query,
                  autocomplete: "off",
                  required: true %>
              <button class="btn btn-secondary btn-lg" type="submit" disabled>
                <i class="fas fa-search me-2"></i>Get Weather
              </button>
            </div>
            <!-- Address Suggestions Dropdown -->
            <div id="address-suggestions" class="list-group position-absolute w-100" style="z-index: 1000; display: none; max-height: 300px; overflow-y: auto; border: 1px solid #dee2e6; border-radius: 0.375rem; box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);">
              <!-- Suggestions will be populated here -->
            </div>
            <div class="form-text">
              <span id="search_help">
                Enter a full address (e.g., "123 Main St, Boston, MA") and select from the suggestions
              </span>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Features Section -->
    <div class="row mt-5">
      <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 text-center">
          <div class="card-body">
            <div class="text-primary mb-3">
              <i class="fas fa-thermometer-half fa-3x"></i>
            </div>
            <h5 class="card-title">Current Temperature</h5>
            <p class="card-text text-muted">
              Get real-time temperature data with detailed weather conditions.
            </p>
          </div>
        </div>
      </div>
      
      <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 text-center">
          <div class="card-body">
            <div class="text-success mb-3">
              <i class="fas fa-chart-line fa-3x"></i>
            </div>
            <h5 class="card-title">High & Low Temps</h5>
            <p class="card-text text-muted">
              View daily temperature ranges and extended forecast information.
            </p>
          </div>
        </div>
      </div>
      
      <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 text-center">
          <div class="card-body">
            <div class="text-info mb-3">
              <i class="fas fa-bolt fa-3x"></i>
            </div>
            <h5 class="card-title">Fast & Cached</h5>
            <p class="card-text text-muted">
              Results are cached for 30 minutes to provide faster responses.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>



